  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --cream: #F8F5F0; --white: #FFFFFF; --ink: #1A1814; --ink-60: #6B6660;
      --ink-30: #B8B4B0; --gold: #B8963E; --gold-light: #D4AF6A;
      --gold-bg: rgba(184,150,62,0.08); --blue: #2C4A7C;
      --border: #E8E4DE;
      --shadow: 0 1px 3px rgba(26,24,20,0.06), 0 4px 16px rgba(26,24,20,0.04);
      --shadow-md: 0 4px 24px rgba(26,24,20,0.10);
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Outfit', sans-serif; background: var(--cream); color: var(--ink); line-height: 1.6; overflow-x: hidden; }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--cream); }
    ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 99px; }

    /* CURSOR */
    .cursor { width: 8px; height: 8px; background: var(--gold); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); }
    .cursor-ring { width: 32px; height: 32px; border: 1.5px solid var(--gold); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9998; transform: translate(-50%,-50%); opacity: 0.45; transition: all 0.1s ease; }

    /* NAV */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 500; display: flex; align-items: center; justify-content: space-between; padding: 1.3rem 5%; background: rgba(248,245,240,0.9); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); }
    .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; letter-spacing: 0.03em; color: var(--ink); text-decoration: none; }
    .nav-logo span { color: var(--gold); }
    .nav-links { display: flex; gap: 2.6rem; list-style: none; align-items: center; }
    .nav-links a { font-size: 0.76rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-60); text-decoration: none; transition: color 0.2s; }
    .nav-links a:hover { color: var(--gold); }
    .nav-cta { padding: 0.5rem 1.3rem; border: 1px solid var(--gold); border-radius: 2px; color: var(--gold) !important; transition: all 0.2s !important; }
    .nav-cta:hover { background: var(--gold) !important; color: var(--white) !important; }

    /* HERO */
    #hero { min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; align-items: center; padding: 7rem 5% 5rem; gap: 4rem; }
    .hero-eyebrow { display: inline-flex; align-items: center; gap: 0.7rem; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.6rem; }
    .eyebrow-line { width: 36px; height: 1px; background: var(--gold); }
    h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(3rem, 5.5vw, 5rem); font-weight: 300; line-height: 1.08; letter-spacing: -0.01em; margin-bottom: 1.5rem; }
    h1 em { font-style: italic; color: var(--gold); }
    .hero-desc { font-size: 0.98rem; color: var(--ink-60); font-weight: 300; line-height: 1.8; max-width: 430px; margin-bottom: 2.2rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn { display: inline-block; padding: 0.82rem 2rem; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; border-radius: 2px; transition: all 0.25s; cursor: pointer; border: none; }
    .btn-gold { background: var(--gold); color: var(--white); }
    .btn-gold:hover { background: #9A7C32; box-shadow: 0 6px 20px rgba(184,150,62,0.35); transform: translateY(-1px); }
    .btn-ghost { border: 1px solid var(--border); color: var(--ink-60); background: transparent; }
    .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }
    .stat-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .stat-card { background: var(--white); border: 1px solid var(--border); border-radius: 8px; padding: 1.6rem 1.4rem; box-shadow: var(--shadow); transition: all 0.25s; }
    .stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 2.4rem; font-weight: 600; line-height: 1; color: var(--gold); margin-bottom: 0.3rem; }
    .stat-label { font-size: 0.78rem; color: var(--ink-60); font-weight: 500; letter-spacing: 0.04em; }
    .stat-sub { font-size: 0.7rem; color: var(--ink-30); margin-top: 0.15rem; }

    /* SECTIONS */
    section { padding: 7rem 5%; }
    .section-wrap { max-width: 1100px; margin: auto; }
    .section-header { margin-bottom: 3.8rem; }
    .section-eyebrow { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem; }
    .section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.9rem, 3.2vw, 2.8rem); font-weight: 400; line-height: 1.1; letter-spacing: -0.01em; }
    .section-title em { font-style: italic; color: var(--gold); }

    /* ABOUT */
    #about { background: var(--white); }
    .about-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
    .about-body { font-size: 0.98rem; color: var(--ink-60); line-height: 1.85; font-weight: 300; }
    .about-body p+p { margin-top: 1rem; }
    .about-quote { border-left: 2px solid var(--gold); padding-left: 1.3rem; margin: 1.6rem 0; font-family: 'Cormorant Garamond', serif; font-size: 1.18rem; font-style: italic; color: var(--ink); line-height: 1.55; }
    .contact-list { list-style: none; display: flex; flex-direction: column; gap: 0; }
    .contact-list li { display: grid; grid-template-columns: 1.5rem 1fr; gap: 1rem; align-items: center; padding: 1rem 0; border-bottom: 1px solid var(--border); }
    .contact-list li:last-child { border-bottom: none; }
    .c-icon { color: var(--gold); font-size: 0.85rem; font-style: normal; }
    .c-info span { display: block; font-size: 0.68rem; color: var(--ink-30); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.18rem; font-weight: 500; }
    .c-info { font-size: 0.86rem; }
    .c-info a { color: var(--blue); text-decoration: none; }
    .c-info a:hover { text-decoration: underline; }

    /* SKILLS */
    #skills { background: var(--cream); }
    .skills-layout { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.4rem; }
    .skill-block { background: var(--white); border: 1px solid var(--border); border-radius: 8px; padding: 1.7rem; transition: all 0.3s; }
    .skill-block:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); border-color: var(--gold-light); }
    .skill-category { font-size: 0.66rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.6rem; }
    .skill-name { font-family: 'Cormorant Garamond', serif; font-size: 1.45rem; font-weight: 600; margin-bottom: 0.45rem; }
    .skill-desc { font-size: 0.8rem; color: var(--ink-60); line-height: 1.6; }
    .skill-meter { height: 2px; background: var(--border); border-radius: 99px; margin-top: 1.1rem; overflow: hidden; }
    .skill-meter-fill { height: 100%; background: linear-gradient(90deg, var(--gold), var(--gold-light)); border-radius: 99px; width: 0%; transition: width 1.2s cubic-bezier(0.22,1,0.36,1) 0.15s; }

    /* EXPERIENCE */
    #experience { background: var(--white); }
    .exp-item { display: grid; grid-template-columns: 190px 1fr; gap: 3rem; padding: 2.6rem 0; border-bottom: 1px solid var(--border); }
    .exp-item:first-child { padding-top: 0; }
    .exp-item:last-child { border-bottom: none; }
    .exp-type { font-size: 0.66rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
    .exp-period { font-size: 0.8rem; color: var(--ink-30); }
    .exp-org { font-size: 0.8rem; color: var(--blue); margin-top: 0.25rem; font-weight: 500; }
    .exp-title { font-family: 'Cormorant Garamond', serif; font-size: 1.45rem; font-weight: 600; margin-bottom: 0.7rem; line-height: 1.2; }
    .exp-desc { font-size: 0.88rem; color: var(--ink-60); line-height: 1.8; font-weight: 300; max-width: 540px; }
    .exp-tags { display: flex; gap: 0.45rem; flex-wrap: wrap; margin-top: 1rem; }
    .exp-tag { padding: 0.22rem 0.7rem; border: 1px solid var(--border); border-radius: 2px; font-size: 0.7rem; color: var(--ink-60); font-weight: 500; letter-spacing: 0.04em; }

    /* PROJECTS */
    #projects { background: var(--cream); }
    .project-card { background: var(--white); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; display: grid; grid-template-columns: 1fr 1.3fr; box-shadow: var(--shadow); transition: box-shadow 0.3s; }
    .project-card:hover { box-shadow: var(--shadow-md); }
    .project-visual { background: linear-gradient(135deg, #1A1814 0%, #2C4A7C 100%); display: flex; align-items: center; justify-content: center; padding: 4rem 3rem; min-height: 300px; position: relative; overflow: hidden; }
    .project-visual::before { content:''; position:absolute; inset:0; background: repeating-linear-gradient(45deg, transparent, transparent 24px, rgba(184,150,62,0.06) 24px, rgba(184,150,62,0.06) 25px); }
    .project-icon-big { font-size: 5rem; position: relative; z-index: 1; }
    .project-body { padding: 2.8rem; }
    .project-label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.7rem; }
    .project-title { font-family: 'Cormorant Garamond', serif; font-size: 1.9rem; font-weight: 600; line-height: 1.15; margin-bottom: 0.9rem; }
    .project-desc { font-size: 0.88rem; color: var(--ink-60); line-height: 1.8; margin-bottom: 1.4rem; font-weight: 300; }
    .tech-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .tech-chip { padding: 0.28rem 0.85rem; background: var(--gold-bg); border: 1px solid rgba(184,150,62,0.2); border-radius: 2px; font-size: 0.72rem; color: var(--gold); font-weight: 600; letter-spacing: 0.06em; }

    /* CREDENTIALS */
    #credentials { background: var(--white); }
    .cred-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; }
    .cred-section-title { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; font-weight: 600; margin-bottom: 1.6rem; padding-bottom: 0.8rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .cred-section-title span { font-size: 0.68rem; font-weight: 500; color: var(--ink-30); letter-spacing: 0.1em; text-transform: uppercase; font-family: 'Outfit', sans-serif; }
    .cert-list { list-style: none; }
    .cert-item { display: flex; align-items: flex-start; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--border); }
    .cert-item:last-child { border-bottom: none; }
    .cert-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); flex-shrink: 0; margin-top: 0.42rem; }
    .cert-name { font-size: 0.88rem; font-weight: 500; margin-bottom: 0.15rem; }
    .cert-issuer { font-size: 0.76rem; color: var(--ink-30); }
    .edu-list { list-style: none; }
    .edu-item { padding: 1.3rem 0; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
    .edu-item:first-child { padding-top: 0; }
    .edu-item:last-child { border-bottom: none; }
    .edu-degree { font-size: 0.9rem; font-weight: 600; margin-bottom: 0.2rem; }
    .edu-inst { font-size: 0.78rem; color: var(--ink-60); }
    .edu-score { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 600; color: var(--gold); white-space: nowrap; }

    /* STRENGTHS */
    #strengths { background: var(--ink); padding: 7rem 5%; }
    #strengths .section-eyebrow { color: var(--gold-light); }
    #strengths .section-title { color: var(--white); }
    #strengths .section-title em { color: var(--gold-light); }
    .strengths-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: rgba(255,255,255,0.07); margin-top: 0; }
    .strength-item { background: var(--ink); padding: 2.6rem 2.2rem; transition: background 0.25s; }
    .strength-item:hover { background: rgba(255,255,255,0.03); }
    .strength-num { font-family: 'Cormorant Garamond', serif; font-size: 2.8rem; font-weight: 300; color: rgba(184,150,62,0.2); line-height: 1; margin-bottom: 1rem; }
    .strength-title { font-size: 0.96rem; font-weight: 600; color: var(--white); margin-bottom: 0.5rem; }
    .strength-desc { font-size: 0.82rem; color: rgba(255,255,255,0.38); line-height: 1.7; font-weight: 300; }

    /* FOOTER */
    footer { background: var(--ink); border-top: 1px solid rgba(255,255,255,0.06); padding: 2.6rem 5%; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
    .footer-name { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 600; color: var(--white); }
    .footer-name span { color: var(--gold); }
    .footer-links { display: flex; gap: 2rem; }
    .footer-links a { font-size: 0.76rem; color: rgba(255,255,255,0.38); text-decoration: none; letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.2s; }
    .footer-links a:hover { color: var(--gold); }
    .footer-right { font-size: 0.76rem; color: rgba(255,255,255,0.25); }

    /* REVEAL */
    .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.65s ease, transform 0.65s ease; }
    .reveal.in { opacity: 1; transform: none; }
    .d1 { transition-delay: 0.1s; } .d2 { transition-delay: 0.2s; } .d3 { transition-delay: 0.3s; }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      #hero, .about-layout, .cred-layout { grid-template-columns: 1fr; }
      .hero-right { display: none; }
      .project-card { grid-template-columns: 1fr; }
      .project-visual { display: none; }
      .skills-layout { grid-template-columns: 1fr 1fr; }
      .strengths-grid { grid-template-columns: 1fr; }
      .exp-item { grid-template-columns: 1fr; gap: 0.4rem; }
      footer { flex-direction: column; align-items: flex-start; }
    }
    @media (max-width: 560px) {
      .skills-layout { grid-template-columns: 1fr; }
      .nav-links { display: none; }
    }
  </style>
</head>
